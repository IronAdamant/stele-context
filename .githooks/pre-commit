#!/usr/bin/env bash
# Pre-commit hook: runs ruff lint, ruff format check, and mypy.
# Install: git config core.hooksPath .githooks
set -e

echo "pre-commit: ruff check..."
ruff check stele/ tests/

echo "pre-commit: ruff format..."
ruff format --check stele/ tests/

echo "pre-commit: mypy..."
mypy stele/ --ignore-missing-imports

echo "pre-commit: all checks passed."
